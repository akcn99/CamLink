{{template "head.tmpl" .}}
<div class="content-header">
  <div class="container-fluid">
    <div class="row mb-2">
      <div class="col-sm-6">
        <h1 class="m-0 text-dark" data-i18n="detection_title">车辆驶入检测</h1>
      </div>
      <div class="col-sm-6">
        <ol class="breadcrumb float-sm-right">
          <li class="breadcrumb-item"><a href="/" data-i18n="nav_home">首页</a></li>
          <li class="breadcrumb-item active" data-i18n="detection_title">车辆驶入检测</li>
        </ol>
      </div>
    </div>
  </div>
</div>
<div class="content">
  <div class="container-fluid">
    <div class="alert alert-info" data-i18n="detection_note">第一阶段先完成配置、服务联通、事件查询骨架；真实画区和目标检测将在后续阶段接入。</div>
    <div class="row">
      <div class="col-12 col-lg-5">
        <div class="card card-outline card-primary">
          <div class="card-header">
            <h3 class="card-title" data-i18n="detection_global">检测服务设置</h3>
          </div>
          <div class="card-body">
            <div class="form-group">
              <label data-i18n="detection_service_url">检测服务地址</label>
              <input id="detectorUrl" class="form-control" type="text" placeholder="http://camlink-detector:8091">
            </div>
            <div class="form-group">
              <label data-i18n="detection_events_db">事件数据库路径(预留)</label>
              <input id="eventsDbPath" class="form-control" type="text" placeholder="save/detection-events.db">
            </div>
            <div class="form-group">
              <label data-i18n="detection_export_dir">报表导出目录</label>
              <input id="exportDir" class="form-control" type="text" placeholder="save/reports">
            </div>
            <div class="form-group">
              <label data-i18n="detection_access_token">Detector Access Token</label>
              <input id="detectorAccessToken" class="form-control" type="text" placeholder="auto-generated">
              <small class="form-text text-muted" data-i18n="detection_access_token_help">Detector 服务访问 CamLink API 时使用的鉴权 token</small>
            </div>
            <button id="saveDetectionSettings" class="btn btn-primary" data-i18n="detection_save_service">保存检测设置</button>
          </div>
        </div>

        <div class="card card-outline card-info">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h3 class="card-title mb-0" data-i18n="detection_service_status">服务状态</h3>
            <button id="refreshDetectorStatus" class="btn btn-outline-info btn-sm" data-i18n="detection_status_refresh">刷新状态</button>
          </div>
          <div class="card-body">
            <div class="mb-2"><strong>URL:</strong> <span id="detectorStatusUrl">-</span></div>
            <div class="mb-2"><strong>Status:</strong> <span id="detectorStatusBadge" class="badge badge-secondary">unknown</span></div>
            <div class="mb-2"><strong data-i18n="detection_event_store">事件库</strong>: <span id="detectorStoreBadge" class="badge badge-secondary">unknown</span></div>
            <div class="small text-muted mb-1" id="detectorStatusMessage">-</div>
            <div class="small text-muted" id="detectorStorePath">-</div>
          </div>
        </div>
      </div>

      <div class="col-12 col-lg-7">
        <div class="card card-outline card-warning">
          <div class="card-header">
            <h3 class="card-title" data-i18n="detection_rules">检测规则</h3>
          </div>
          <div class="card-body">
            <div class="form-row">
              <div class="form-group col-md-6">
                <label data-i18n="detection_target_stream">目标摄像头</label>
                <select id="targetStream" class="form-control"></select>
              </div>
              <div class="form-group col-md-6">
                <label data-i18n="detection_target_channel">目标通道</label>
                <select id="targetChannel" class="form-control"></select>
              </div>
            </div>
            <div class="form-group">
              <label data-i18n="detection_stream_url">RTSP 地址</label>
              <input id="targetStreamUrl" class="form-control" type="text" readonly>
            </div>
            <div class="form-group">
              <label data-i18n="detection_mode">检测模式</label>
              <select id="detectionMode" class="form-control">
                <option value="vehicle_entry">vehicle_entry</option>
              </select>
            </div>
            <div class="form-group">
              <div class="custom-control custom-switch">
                <input type="checkbox" class="custom-control-input" id="detectionEnabled">
                <label class="custom-control-label" for="detectionEnabled" data-i18n="detection_enabled">启用车辆驶入检测</label>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group col-md-4">
                <label data-i18n="detection_sample_fps">检测帧率(每秒帧数)</label>
                <input id="sampleFps" class="form-control" type="number" min="1" max="5" value="1">
              </div>
              <div class="form-group col-md-4">
                <label data-i18n="detection_cooldown">告警冷却时间(秒)</label>
                <input id="cooldownSeconds" class="form-control" type="number" min="1" max="3600" value="30">
                <small class="form-text text-muted" data-i18n="detection_cooldown_help">用于屏蔽短时间内重复事件</small>
              </div>
              <div class="form-group col-md-4">
                <label data-i18n="detection_consecutive">进入判定连续帧数</label>
                <input id="consecutiveFrames" class="form-control" type="number" min="1" max="10" value="2">
              </div>
            </div>
            <div class="form-row">
              <div class="form-group col-md-4">
                <label data-i18n="detection_direction">进入方向</label>
                <select id="entryDirection" class="form-control">
                  <option value="any" data-i18n="detection_direction_any">不限</option>
                  <option value="left_to_right" data-i18n="detection_direction_ltr">从左到右</option>
                  <option value="right_to_left" data-i18n="detection_direction_rtl">从右到左</option>
                  <option value="top_to_bottom" data-i18n="detection_direction_ttb">从上到下</option>
                  <option value="bottom_to_top" data-i18n="detection_direction_btt">从下到上</option>
                </select>
                <small class="form-text text-muted" data-i18n="detection_direction_help">仅在方向符合时触发进入事件</small>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group col-md-4">
                <label data-i18n="detection_confidence">置信度阈值</label>
                <input id="confidenceThreshold" class="form-control" type="number" min="0.05" max="0.95" step="0.05" value="0.35">
                <small class="form-text text-muted" data-i18n="detection_confidence_help">提高阈值可减少误报</small>
              </div>
              <div class="form-group col-md-4">
                <label data-i18n="detection_min_area">最小目标面积(像素)</label>
                <input id="minBoxArea" class="form-control" type="number" min="0" step="100" value="1200">
                <small class="form-text text-muted" data-i18n="detection_min_area_help">过滤小噪点或远处误检</small>
              </div>
              <div class="form-group col-md-4">
                <label data-i18n="detection_min_move">最小进入位移(像素)</label>
                <input id="minMovePx" class="form-control" type="number" min="0" step="1" value="12">
                <small class="form-text text-muted" data-i18n="detection_min_move_help">过滤静止物体抖动触发</small>
              </div>
            </div>
            <div class="form-group">
              <label data-i18n="detection_classes">检测类别</label>
              <div class="d-flex flex-wrap">
                <div class="custom-control custom-checkbox mr-3">
                  <input class="custom-control-input detection-class" type="checkbox" id="classCar" value="car" checked>
                  <label class="custom-control-label" for="classCar">car</label>
                </div>
                <div class="custom-control custom-checkbox mr-3">
                  <input class="custom-control-input detection-class" type="checkbox" id="classMotorcycle" value="motorcycle" checked>
                  <label class="custom-control-label" for="classMotorcycle">motorcycle</label>
                </div>
                <div class="custom-control custom-checkbox mr-3">
                  <input class="custom-control-input detection-class" type="checkbox" id="classBicycle" value="bicycle" checked>
                  <label class="custom-control-label" for="classBicycle">bicycle</label>
                </div>
              </div>
            </div>
            <div class="form-group">
              <label data-i18n="detection_polygon">检测区域多边形(JSON)</label>
              <textarea id="polygonJson" class="form-control" rows="5" placeholder='[{"x":120,"y":80},{"x":580,"y":90},{"x":620,"y":410}]'></textarea>
              <small class="form-text text-muted" data-i18n="detection_polygon_help">可直接填写 JSON，或使用画区工具生成坐标。</small>
              <div class="mt-2">
                <button type="button" class="btn btn-outline-primary btn-sm" id="openDrawPanel" data-i18n="detection_draw_open">打开画区面板</button>
                <button type="button" class="btn btn-outline-secondary btn-sm ml-2" id="clearPolygon" data-i18n="detection_draw_clear_polygon">清空区域</button>
              </div>
            </div>
            <div class="form-group">
              <label data-i18n="detection_entry_line">进入方向线(JSON)</label>
              <textarea id="entryLineJson" class="form-control" rows="2" placeholder='[{"x":120,"y":200},{"x":520,"y":200}]'></textarea>
              <small class="form-text text-muted" data-i18n="detection_entry_line_help">使用 2 个点表示方向线，配置后只触发跨越该线的进入事件。</small>
              <div class="mt-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="clearEntryLine" data-i18n="detection_draw_clear_line">清空方向线</button>
              </div>
            </div>
            <div class="form-group">
              <div class="custom-control custom-switch">
                <input type="checkbox" class="custom-control-input" id="telegramEnabled">
                <label class="custom-control-label" for="telegramEnabled" data-i18n="detection_telegram">Telegram 通知</label>
              </div>
            </div>
            <div class="form-group">
              <label data-i18n="detection_telegram_chat">Telegram Chat ID</label>
              <input id="telegramChatId" class="form-control" type="text" placeholder="123456789">
            </div>
            <div class="d-flex flex-wrap">
              <button id="saveDetectionRules" class="btn btn-warning mr-2 mb-2" data-i18n="detection_save_rules">保存规则</button>
              <button id="mockDetectionEvent" class="btn btn-outline-secondary mb-2" data-i18n="detection_mock_event">写入测试事件</button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-12">
        <div class="card card-outline card-success">
          <div class="card-header">
            <h3 class="card-title" data-i18n="detection_stats">统计与报表</h3>
          </div>
          <div class="card-body">
            <div class="form-row align-items-end">
              <div class="form-group col-md-3">
                <label data-i18n="detection_target_stream">目标摄像头</label>
                <select id="queryStream" class="form-control"></select>
              </div>
              <div class="form-group col-md-2">
                <label data-i18n="detection_target_channel">目标通道</label>
                <select id="queryChannel" class="form-control"></select>
              </div>
              <div class="form-group col-md-2">
                <label data-i18n="detection_object_class">目标类别</label>
                <select id="queryClass" class="form-control">
                  <option value="">ALL</option>
                  <option value="car">car</option>
                  <option value="motorcycle">motorcycle</option>
                  <option value="bicycle">bicycle</option>
                </select>
              </div>
              <div class="form-group col-md-2">
                <label>Start</label>
                <input id="queryStart" class="form-control" type="datetime-local">
              </div>
              <div class="form-group col-md-2">
                <label>End</label>
                <input id="queryEnd" class="form-control" type="datetime-local">
              </div>
              <div class="form-group col-md-1 text-right">
                <button id="queryDetectionEvents" class="btn btn-success btn-block" data-i18n="detection_query">查询事件</button>
              </div>
            </div>
            <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
              <div><strong data-i18n="detection_events_total">事件总数</strong>: <span id="eventsTotal">0</span></div>
              <button id="exportDetectionEvents" class="btn btn-outline-success" data-i18n="detection_export">导出 CSV</button>
            </div>
            <div class="table-responsive">
              <table class="table table-bordered table-hover">
                <thead>
                  <tr>
                    <th data-i18n="detection_entered_at">进入时间</th>
                    <th data-i18n="detection_target_stream">目标摄像头</th>
                    <th data-i18n="detection_target_channel">目标通道</th>
                    <th data-i18n="detection_object_class">目标类别</th>
                    <th data-i18n="detection_track_id">轨迹ID</th>
                    <th data-i18n="detection_snapshot">截图</th>
                  </tr>
                </thead>
                <tbody id="eventsTableBody">
                  <tr><td colspan="6" class="text-center text-muted" data-i18n="detection_empty">当前时间段没有检测事件</td></tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="drawDetectionModal" tabindex="-1" role="dialog" aria-labelledby="drawDetectionLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="drawDetectionLabel" data-i18n="detection_draw_title">画区工具</h5>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body">
        <div class="row">
          <div class="col-lg-9 mb-3">
            <div class="detection-canvas-wrap border rounded">
              <canvas id="detectionCanvas"></canvas>
            </div>
          </div>
          <div class="col-lg-3">
            <div class="btn-group-vertical w-100 mb-3">
              <button type="button" class="btn btn-outline-primary" id="drawPolygonMode" data-i18n="detection_draw_polygon">绘制检测区域</button>
              <button type="button" class="btn btn-outline-primary" id="drawLineMode" data-i18n="detection_draw_line">绘制方向线</button>
              <button type="button" class="btn btn-outline-secondary" id="drawUndo" data-i18n="detection_draw_undo">撤销</button>
              <button type="button" class="btn btn-outline-danger" id="drawClearAll" data-i18n="detection_draw_clear_all">清空</button>
            </div>
            <button type="button" class="btn btn-outline-info w-100 mb-3" id="drawRefresh" data-i18n="detection_draw_refresh">抓取当前画面</button>
            <div class="custom-control custom-switch mb-2">
              <input type="checkbox" class="custom-control-input" id="drawUseRelative" checked>
              <label class="custom-control-label" for="drawUseRelative" data-i18n="detection_draw_relative">保存为相对坐标</label>
            </div>
            <small class="text-muted" data-i18n="detection_draw_help">点击画面添加点位，双击结束多边形，方向线只需两点。</small>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" id="applyDrawToForm" data-i18n="detection_draw_apply">应用到表单</button>
        <button type="button" class="btn btn-secondary" data-dismiss="modal" data-i18n="cancel">取消</button>
      </div>
    </div>
  </div>
</div>

<style>
  .detection-canvas-wrap {
    position: relative;
    width: 100%;
    min-height: 360px;
    background: #101418;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: auto;
  }
  #detectionCanvas {
    max-width: 100%;
    height: auto;
    cursor: crosshair;
  }
</style>
{{template "foot.tmpl" .}}
<script>
  const initialStreamUUID = '{{ .initial_uuid }}';
  const initialChannelID = '{{ .initial_channel }}';
  let detectionOverview = [];
  let preferredStreamUUID = '';
  let preferredChannelID = '';
  let drawCanvas = null;
  let drawCtx = null;
  let drawImage = null;
  let drawMode = 'polygon';
  let drawPolygonPoints = [];
  let drawLinePoints = [];

  $(document).ready(function () {
    loadDetectionSettings();
    loadDetectionOverview();
    refreshDetectorStatus();
    bindDetectionActions();
    initDrawCanvas();
  });

  function bindDetectionActions() {
    $("#refreshDetectorStatus").on("click", refreshDetectorStatus);
    $("#saveDetectionSettings").on("click", saveDetectionSettings);
    $("#saveDetectionRules").on("click", saveDetectionRules);
    $("#targetStream").on("change", function () {
      fillChannelSelectors($("#targetChannel"), $(this).val(), "0");
      preferredStreamUUID = $(this).val();
      preferredChannelID = $("#targetChannel").val();
      loadSelectedDetectionConfig();
    });
    $("#targetChannel").on("change", function () {
      preferredChannelID = $(this).val();
      loadSelectedDetectionConfig();
    });
    $("#queryStream").on("change", function () {
      fillChannelSelectors($("#queryChannel"), $(this).val(), "0");
    });
    $("#queryDetectionEvents").on("click", loadDetectionEvents);
    $("#exportDetectionEvents").on("click", exportDetectionEvents);
    $("#mockDetectionEvent").on("click", createMockDetectionEvent);
    $("#openDrawPanel").on("click", openDrawPanel);
    $("#clearPolygon").on("click", function () { $("#polygonJson").val("[]"); });
    $("#clearEntryLine").on("click", function () { $("#entryLineJson").val("[]"); });
    $("#drawPolygonMode").on("click", function () { setDrawMode('polygon'); });
    $("#drawLineMode").on("click", function () { setDrawMode('line'); });
    $("#drawUndo").on("click", drawUndoPoint);
    $("#drawClearAll").on("click", drawClearAll);
    $("#drawRefresh").on("click", loadDrawSnapshot);
    $("#applyDrawToForm").on("click", applyDrawToForm);
  }

  function initDrawCanvas() {
    drawCanvas = document.getElementById("detectionCanvas");
    if (!drawCanvas) {
      return;
    }
    drawCtx = drawCanvas.getContext("2d");
    drawImage = new Image();
    drawImage.onload = function () {
      drawCanvas.width = drawImage.naturalWidth;
      drawCanvas.height = drawImage.naturalHeight;
      hydrateDrawPointsFromForm();
      redrawCanvas();
    };
    drawImage.onerror = function () {
      Swal.fire({ icon: "error", title: t("error"), text: t("detection_draw_load_failed"), confirmButtonText: t("ok") });
    };
    drawCanvas.addEventListener("click", function (event) {
      if (!drawImage || !drawImage.naturalWidth) {
        return;
      }
      const point = canvasPointFromEvent(drawCanvas, event);
      if (drawMode === 'polygon') {
        drawPolygonPoints.push(point);
      } else {
        if (drawLinePoints.length >= 2) {
          drawLinePoints = [];
        }
        drawLinePoints.push(point);
      }
      redrawCanvas();
    });
    drawCanvas.addEventListener("dblclick", function () {
      if (drawMode === 'polygon') {
        redrawCanvas();
      }
    });
  }

  function canvasPointFromEvent(canvas, event) {
    const rect = canvas.getBoundingClientRect();
    const scaleX = canvas.width / rect.width;
    const scaleY = canvas.height / rect.height;
    return {
      x: Math.round((event.clientX - rect.left) * scaleX),
      y: Math.round((event.clientY - rect.top) * scaleY)
    };
  }

  function openDrawPanel() {
    $("#drawDetectionModal").modal("show");
    setDrawMode("polygon");
    loadDrawSnapshot();
  }

  function loadDrawSnapshot() {
    const uuid = $("#targetStream").val();
    const channel = $("#targetChannel").val();
    if (!uuid || !channel) {
      return;
    }
    const url = "/detection/snapshot/" + encodeURIComponent(uuid) + "/" + encodeURIComponent(channel) + "?ts=" + Date.now();
    drawImage.src = url;
  }

  function hydrateDrawPointsFromForm() {
    drawPolygonPoints = parsePointJson($("#polygonJson").val(), drawImage.naturalWidth, drawImage.naturalHeight);
    drawLinePoints = parsePointJson($("#entryLineJson").val(), drawImage.naturalWidth, drawImage.naturalHeight);
    redrawCanvas();
  }

  function parsePointJson(text, w, h) {
    const trimmed = (text || "").trim();
    if (!trimmed) {
      return [];
    }
    try {
      const points = JSON.parse(trimmed);
      if (!Array.isArray(points)) {
        return [];
      }
      let maxX = 0;
      let maxY = 0;
      points.forEach(function (p) {
        maxX = Math.max(maxX, Number(p.x || 0));
        maxY = Math.max(maxY, Number(p.y || 0));
      });
      const isRatio = maxX <= 1.01 && maxY <= 1.01;
      return points.map(function (p) {
        const x = Number(p.x || 0);
        const y = Number(p.y || 0);
        return {
          x: isRatio ? Math.round(x * w) : Math.round(x),
          y: isRatio ? Math.round(y * h) : Math.round(y)
        };
      });
    } catch (err) {
      return [];
    }
  }

  function setDrawMode(mode) {
    drawMode = mode;
    $("#drawPolygonMode").toggleClass("active", mode === "polygon");
    $("#drawLineMode").toggleClass("active", mode === "line");
  }

  function drawUndoPoint() {
    if (drawMode === 'polygon' && drawPolygonPoints.length) {
      drawPolygonPoints.pop();
    } else if (drawMode === 'line' && drawLinePoints.length) {
      drawLinePoints.pop();
    }
    redrawCanvas();
  }

  function drawClearAll() {
    drawPolygonPoints = [];
    drawLinePoints = [];
    redrawCanvas();
  }

  function applyDrawToForm() {
    const useRelative = $("#drawUseRelative").prop("checked");
    const w = drawCanvas.width || 1;
    const h = drawCanvas.height || 1;
    $("#polygonJson").val(JSON.stringify(serializePoints(drawPolygonPoints, useRelative, w, h), null, 2));
    $("#entryLineJson").val(JSON.stringify(serializePoints(drawLinePoints, useRelative, w, h), null, 2));
    $("#drawDetectionModal").modal("hide");
  }

  function serializePoints(points, useRelative, w, h) {
    return points.map(function (p) {
      if (useRelative) {
        return {
          x: Number((p.x / w).toFixed(4)),
          y: Number((p.y / h).toFixed(4))
        };
      }
      return { x: Math.round(p.x), y: Math.round(p.y) };
    });
  }

  function redrawCanvas() {
    if (!drawCanvas || !drawCtx) {
      return;
    }
    if (drawImage && drawImage.naturalWidth) {
      drawCtx.clearRect(0, 0, drawCanvas.width, drawCanvas.height);
      drawCtx.drawImage(drawImage, 0, 0);
    } else {
      drawCtx.clearRect(0, 0, drawCanvas.width, drawCanvas.height);
    }
    drawCtx.lineWidth = 2;
    drawCtx.strokeStyle = "#00d1b2";
    drawCtx.fillStyle = "rgba(0, 209, 178, 0.2)";
    if (drawPolygonPoints.length >= 2) {
      drawCtx.beginPath();
      drawCtx.moveTo(drawPolygonPoints[0].x, drawPolygonPoints[0].y);
      for (let i = 1; i < drawPolygonPoints.length; i++) {
        drawCtx.lineTo(drawPolygonPoints[i].x, drawPolygonPoints[i].y);
      }
      if (drawPolygonPoints.length >= 3) {
        drawCtx.lineTo(drawPolygonPoints[0].x, drawPolygonPoints[0].y);
        drawCtx.fill();
      }
      drawCtx.stroke();
    }
    drawCtx.strokeStyle = "#ff6b6b";
    if (drawLinePoints.length === 2) {
      drawCtx.beginPath();
      drawCtx.moveTo(drawLinePoints[0].x, drawLinePoints[0].y);
      drawCtx.lineTo(drawLinePoints[1].x, drawLinePoints[1].y);
      drawCtx.stroke();
      drawCtx.fillStyle = "#ff6b6b";
      drawCtx.beginPath();
      drawCtx.arc(drawLinePoints[1].x, drawLinePoints[1].y, 5, 0, Math.PI * 2);
      drawCtx.fill();
    }
  }

  function loadDetectionSettings() {
    $.get("/detection/settings/global", function (resp) {
      if (!resp || resp.status !== 1) {
        return;
      }
      const s = resp.payload || {};
      $("#detectorUrl").val(s.detector_url || "");
      $("#eventsDbPath").val(s.events_db_path || "");
      $("#exportDir").val(s.export_dir || "");
      $("#detectorAccessToken").val(s.access_token || "");
    });
  }

  function saveDetectionSettings() {
    const body = {
      detector_url: $("#detectorUrl").val().trim(),
      events_db_path: $("#eventsDbPath").val().trim(),
      export_dir: $("#exportDir").val().trim(),
      access_token: $("#detectorAccessToken").val().trim()
    };
    $.ajax({
      url: "/detection/settings/global",
      type: "POST",
      contentType: "application/json",
      data: JSON.stringify(body),
      success: function () {
        Swal.fire({ icon: "success", title: t("saved"), confirmButtonText: t("ok") });
        refreshDetectorStatus();
      },
      error: function (xhr) {
        Swal.fire({ icon: "error", title: t("error"), text: (xhr.responseJSON && xhr.responseJSON.payload) || t("save_failed"), confirmButtonText: t("ok") });
      }
    });
  }

  function loadDetectionOverview() {
    $.get("/detection/overview", function (resp) {
      if (!resp || resp.status !== 1) {
        return;
      }
      detectionOverview = resp.payload || [];
      fillTargetSelectors();
      loadSelectedDetectionConfig();
      loadDetectionEvents();
    });
  }

  function fillTargetSelectors() {
    const streamSelect = $("#targetStream");
    const channelSelect = $("#targetChannel");
    const queryStream = $("#queryStream");
    const queryChannel = $("#queryChannel");
    streamSelect.empty();
    queryStream.empty();

    const streamMap = {};
    detectionOverview.forEach(function (item) {
      if (!streamMap[item.stream_uuid]) {
        streamMap[item.stream_uuid] = item.stream_name || item.stream_uuid;
      }
    });

    Object.keys(streamMap).forEach(function (uuid) {
      const label = streamMap[uuid];
      streamSelect.append('<option value="' + uuid + '">' + label + ' (' + uuid + ')</option>');
      queryStream.append('<option value="' + uuid + '">' + label + ' (' + uuid + ')</option>');
    });

    if (preferredStreamUUID && streamMap[preferredStreamUUID]) {
      streamSelect.val(preferredStreamUUID);
      queryStream.val(preferredStreamUUID);
    } else if (initialStreamUUID && streamMap[initialStreamUUID]) {
      streamSelect.val(initialStreamUUID);
      queryStream.val(initialStreamUUID);
    }
    const chosenStream = streamSelect.val();
    const chosenChannel = preferredChannelID || initialChannelID;
    fillChannelSelectors(channelSelect, chosenStream, chosenChannel);
    fillChannelSelectors(queryChannel, queryStream.val(), chosenChannel);
  }

  function fillChannelSelectors(selectEl, streamUUID, preferredChannel) {
    selectEl.empty();
    detectionOverview.filter(function (item) {
      return item.stream_uuid === streamUUID;
    }).forEach(function (item) {
      selectEl.append('<option value="' + item.channel_id + '">Channel ' + item.channel_id + '</option>');
    });
    if (preferredChannel) {
      selectEl.val(preferredChannel);
    }
  }

  function currentOverviewItem() {
    const uuid = $("#targetStream").val();
    const channel = $("#targetChannel").val();
    return detectionOverview.find(function (item) {
      return item.stream_uuid === uuid && item.channel_id === channel;
    }) || null;
  }

  function loadSelectedDetectionConfig() {
    const uuid = $("#targetStream").val();
    const channel = $("#targetChannel").val();
    if (!uuid || !channel) {
      return;
    }
    $.get('/detection/config/' + encodeURIComponent(uuid) + '/' + encodeURIComponent(channel), function (resp) {
      if (!resp || resp.status !== 1) {
        return;
      }
      const payload = resp.payload || {};
      const detection = payload.detection || {};
      $("#targetStreamUrl").val(payload.stream_url || "");
      $("#detectionMode").val(detection.mode || "vehicle_entry");
      $("#detectionEnabled").prop("checked", !!detection.enabled);
      $("#sampleFps").val(detection.sample_fps || 1);
      $("#cooldownSeconds").val(detection.cooldown_seconds || 30);
      $("#consecutiveFrames").val(detection.trigger_consecutive_frames || 2);
      $("#entryDirection").val(detection.entry_direction || "any");
      const conf = (detection.confidence_threshold != null) ? detection.confidence_threshold : 0.35;
      const minArea = (detection.min_box_area != null) ? detection.min_box_area : 1200;
      const minMove = (detection.min_move_px != null) ? detection.min_move_px : 12;
      $("#confidenceThreshold").val(conf);
      $("#minBoxArea").val(minArea);
      $("#minMovePx").val(minMove);
      $("#telegramEnabled").prop("checked", !!detection.telegram_enabled);
      $("#telegramChatId").val(detection.telegram_chat_id || "");
      $("#polygonJson").val(JSON.stringify(detection.polygon || [], null, 2));
      $("#entryLineJson").val(JSON.stringify(detection.entry_line || [], null, 2));
      const classes = detection.classes || [];
      $(".detection-class").each(function () {
        $(this).prop("checked", classes.indexOf($(this).val()) >= 0);
      });
      $("#queryStream").val(uuid);
      fillChannelSelectors($("#queryChannel"), uuid, channel);
      preferredStreamUUID = uuid;
      preferredChannelID = channel;
    });
  }

  function saveDetectionRules() {
    const uuid = $("#targetStream").val();
    const channel = $("#targetChannel").val();
    if (!uuid || !channel) {
      return;
    }
    let polygon = [];
    const polygonText = $("#polygonJson").val().trim();
    if (polygonText) {
      try {
        polygon = JSON.parse(polygonText);
      } catch (err) {
        Swal.fire({ icon: "error", title: t("error"), text: "Polygon JSON 格式不正确", confirmButtonText: t("ok") });
        return;
      }
    }
    let entryLine = [];
    const entryLineText = $("#entryLineJson").val().trim();
    if (entryLineText) {
      try {
        entryLine = JSON.parse(entryLineText);
      } catch (err) {
        Swal.fire({ icon: "error", title: t("error"), text: "Entry line JSON 格式不正确", confirmButtonText: t("ok") });
        return;
      }
      if (entryLine.length !== 0 && entryLine.length !== 2) {
        Swal.fire({ icon: "error", title: t("error"), text: "进入方向线需要两个点", confirmButtonText: t("ok") });
        return;
      }
    }
    const sampleFpsVal = parseInt($("#sampleFps").val(), 10);
    const cooldownVal = parseInt($("#cooldownSeconds").val(), 10);
    const consecutiveVal = parseInt($("#consecutiveFrames").val(), 10);
    const confVal = parseFloat($("#confidenceThreshold").val());
    const minBoxVal = parseInt($("#minBoxArea").val(), 10);
    const minMoveVal = parseInt($("#minMovePx").val(), 10);
    const body = {
      enabled: $("#detectionEnabled").prop("checked"),
      mode: $("#detectionMode").val(),
      entry_direction: $("#entryDirection").val(),
      sample_fps: Number.isNaN(sampleFpsVal) ? 1 : sampleFpsVal,
      cooldown_seconds: Number.isNaN(cooldownVal) ? 30 : cooldownVal,
      confidence_threshold: Number.isNaN(confVal) ? 0.35 : confVal,
      min_box_area: Number.isNaN(minBoxVal) ? 1200 : minBoxVal,
      min_move_px: Number.isNaN(minMoveVal) ? 12 : minMoveVal,
      classes: $(".detection-class:checked").map(function () { return $(this).val(); }).get(),
      polygon: polygon,
      entry_line: entryLine,
      trigger_consecutive_frames: Number.isNaN(consecutiveVal) ? 2 : consecutiveVal,
      telegram_enabled: $("#telegramEnabled").prop("checked"),
      telegram_chat_id: $("#telegramChatId").val().trim()
    };
    $.ajax({
      url: '/detection/config/' + encodeURIComponent(uuid) + '/' + encodeURIComponent(channel),
      type: 'POST',
      contentType: 'application/json',
      data: JSON.stringify(body),
      success: function () {
        Swal.fire({ icon: 'success', title: t('saved'), confirmButtonText: t('ok') });
        preferredStreamUUID = uuid;
        preferredChannelID = channel;
        loadDetectionOverview();
      },
      error: function (xhr) {
        Swal.fire({ icon: 'error', title: t('error'), text: (xhr.responseJSON && xhr.responseJSON.payload) || t('save_failed'), confirmButtonText: t('ok') });
      }
    });
  }

  function createMockDetectionEvent() {
    const uuid = $("#targetStream").val();
    const channel = $("#targetChannel").val();
    if (!uuid || !channel) {
      return;
    }
    $.ajax({
      url: '/detection/events/mock/' + encodeURIComponent(uuid) + '/' + encodeURIComponent(channel),
      type: 'POST',
      success: function () {
        Swal.fire({ icon: 'success', title: t('saved'), text: t('detection_mock_success'), confirmButtonText: t('ok') });
        $("#queryStream").val(uuid);
        fillChannelSelectors($("#queryChannel"), uuid, channel);
        loadDetectionEvents();
        refreshDetectorStatus();
      },
      error: function (xhr) {
        Swal.fire({ icon: 'error', title: t('error'), text: (xhr.responseJSON && xhr.responseJSON.payload) || t('save_failed'), confirmButtonText: t('ok') });
      }
    });
  }

  function refreshDetectorStatus() {
    $.get('/detection/service/status', function (resp) {
      if (!resp || resp.status !== 1) {
        return;
      }
      const payload = resp.payload || {};
      $('#detectorStatusUrl').text(payload.configured_url || '-');
      const badge = $('#detectorStatusBadge');
      badge.removeClass('badge-success badge-danger badge-secondary');
      if (payload.reachable) {
        badge.addClass('badge-success').text('online');
      } else if (payload.configured_url) {
        badge.addClass('badge-danger').text('offline');
      } else {
        badge.addClass('badge-secondary').text('not-configured');
      }
      $('#detectorStatusMessage').text(payload.message || '-');

      const store = payload.event_store || {};
      const storeBadge = $('#detectorStoreBadge');
      storeBadge.removeClass('badge-success badge-danger badge-secondary');
      if (store.ready) {
        storeBadge.addClass('badge-success').text('ready');
      } else if (store.db_path) {
        storeBadge.addClass('badge-danger').text('error');
      } else {
        storeBadge.addClass('badge-secondary').text('not-configured');
      }
      const pathText = store.db_path ? ('DB: ' + store.db_path + ' | Export: ' + (store.export_dir || '-')) : '-';
      $('#detectorStorePath').text(pathText);
    });
  }

  function toISOStringFromLocalInput(value) {
    if (!value) {
      return '';
    }
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) {
      return value;
    }
    return date.toISOString();
  }

  function buildEventQuery() {
    return {
      stream_uuid: $('#queryStream').val() || '',
      channel_id: $('#queryChannel').val() || '',
      object_class: $('#queryClass').val() || '',
      start: toISOStringFromLocalInput($('#queryStart').val() || ''),
      end: toISOStringFromLocalInput($('#queryEnd').val() || '')
    };
  }

  function loadDetectionEvents() {
    $.get('/detection/events', buildEventQuery(), function (resp) {
      if (!resp || resp.status !== 1) {
        return;
      }
      const payload = resp.payload || {};
      const events = payload.events || [];
      $('#eventsTotal').text((payload.summary && payload.summary.total) || 0);
      const tbody = $('#eventsTableBody');
      tbody.empty();
      if (!events.length) {
        tbody.append('<tr><td colspan="6" class="text-center text-muted">' + t('detection_empty') + '</td></tr>');
        return;
      }
      events.forEach(function (event) {
        const snapshot = event.snapshot_path ? '<code>' + event.snapshot_path + '</code>' : t('detection_no_snapshot');
        tbody.append('<tr>' +
          '<td>' + new Date(event.entered_at).toLocaleString("zh-CN", { timeZone: "Asia/Shanghai" }) + '</td>' +
          '<td>' + (event.stream_name || event.stream_uuid) + '</td>' +
          '<td>' + event.channel_id + '</td>' +
          '<td>' + event.object_class + '</td>' +
          '<td>' + (event.track_id || '-') + '</td>' +
          '<td>' + snapshot + '</td>' +
          '</tr>');
      });
    });
  }

  function exportDetectionEvents() {
    const query = $.param(buildEventQuery());
    window.location.href = '/detection/events/export?' + query;
  }
</script>
